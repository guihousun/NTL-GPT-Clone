# Required
DASHSCOPE_API_KEY=
DASHSCOPE_Qwen_plus_KEY=
DASHSCOPE_Qwen_plus_URL=
DASHSCOPE_Coding_URL=
MINIMAX_API_KEY=
MINIMAX_Coding_URL=https://api.minimaxi.com/v1

# Optional runtime settings
NTL_TOOL_PROFILE=default
NTL_USER_DATA_DIR=
NTL_SHARED_DATA_DIR=
NTL_THREAD_ID=
NTL_CONTEXTILY_TMP=
NTL_MAX_ACTIVE_RUNS=10
NTL_MAX_ACTIVE_RUNS_PER_USER=2

# Optional production persistence.
# If NTL_LANGGRAPH_POSTGRES_URL is set, LangGraph checkpoints and Store use Postgres.
# NTL_DEEPAGENTS_MEMORY_BACKEND=auto uses StoreBackend with Postgres and filesystem otherwise.
NTL_LANGGRAPH_POSTGRES_URL=
NTL_LANGGRAPH_POSTGRES_AUTO_SETUP=1
NTL_DEEPAGENTS_MEMORY_BACKEND=auto
NTL_MEMORY_NAMESPACE_SCOPE=thread

# Optional external services
# Default hosted GEE pipeline used as fallback when a user has not configured
# their own GEE Project ID in the sidebar.
GEE_DEFAULT_PROJECT_ID=
# Optional Google OAuth for user-owned GEE pipeline.
# Generate the encryption key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/earthengine https://www.googleapis.com/auth/cloud-platform
NTL_TOKEN_ENCRYPTION_KEY=
EARTHDATA_TOKEN=

# Optional only if you use local OpenAI-backed RAG / embeddings
# OPENAI_API_KEY=

# Optional only if you use Google BigQuery features
# GOOGLE_APPLICATION_CREDENTIALS=
