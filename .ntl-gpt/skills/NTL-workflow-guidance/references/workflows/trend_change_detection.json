          "temporal_resolution": "annual",
          "dataset_name": "NPP-VIIRS-Like",
          "time_range_input": "2020 to 2024",
          "out_name": "NTL_time_series.tif",
          "is_in_China": true
        }
      },
      {
        "type": "builtin_tool",
        "name": "Detect_NTL_anomaly",
        "input": {
          "raster_files": [
