            "NTL_2022.tif",
            "NTL_2023.tif",
            "NTL_2024.tif"
          ],
          "k_sigma": 3.0,
          "target_index": null,
          "save_filename": "NTL_anomaly_mask.tif"
        }
      }
    ],
    "output": "outputs/NTL_anomaly_mask.tif - Binary mask showing anomalous areas"
  },
