[
  {
    "task_id": "Q18",
    "task_name": "Trend analysis of NTL in Shanghai (2010–2020)",
    "category": "NTL statistics",
    "description": "Examine the long-term luminosity dynamics of Shanghai by performing a spatiotemporal trend analysis (Sen's Slope and Mann-Kendall test) on annual NPP-VIIRS-Like data from 2010 to 2020.",
    "steps": [
      {
        "type": "builtin_tool",
        "name": "NTL_download_tool",
        "input": {
          "study_area": "上海市",
          "scale_level": "province",
          "temporal_resolution": "annual",
          "dataset_name": "NPP-VIIRS-Like",
          "time_range_input": "2010 to 2020",
          "out_name": "Shanghai_NTL.tif",
          "is_in_China": true
        }
      },
      {
        "type": "builtin_tool",
        "name": "Analyze_NTL_trend",
        "input": {
          "raster_files": [
            "Shanghai_NTL_2010.tif",
            "Shanghai_NTL_2011.tif",
            "Shanghai_NTL_2012.tif",
            "Shanghai_NTL_2013.tif",
            "Shanghai_NTL_2014.tif",
            "Shanghai_NTL_2015.tif",
            "Shanghai_NTL_2016.tif",
            "Shanghai_NTL_2017.tif",
            "Shanghai_NTL_2018.tif",
            "Shanghai_NTL_2019.tif",
            "Shanghai_NTL_2020.tif"
          ],
          "save_subfolder": "Shanghai_Trend_2010_2020"
        }
      }
    ],
    "output": [
      "outputs/Shanghai_Trend_2010_2020/slope_map.tif",
      "outputs/Shanghai_Trend_2010_2020/significance_map.tif"
    ]
  }
]
